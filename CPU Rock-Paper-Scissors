/*
This program is a rock-paper-scissors game between 2 "CPUs"
0 represents rock, 1 represents paper, and 2 represents scissors.
*/

#include<iostream>
#include<string>
#include<ctime>
#include<cstdlib>
using namespace std;

int Winner(int P1, int P2)
{
    if (P1 == P2)//Tie -> Case 1
		return 0;

	else 
	{
		if (P1 == (P2 - 2))
			return 1; //Player 1 wins

		else if (P1 == (P2 + 1))
			return 1; //Player 1 wins

		else
			return 2; //Player 2 wins
	}
}

int main()
{
    int P1_int_val;
    int P2_int_val;
    string P1_string_val;
    string P2_string_val;
    
    unsigned seed = time(NULL);
    srand(seed);
    
    P1_int_val = rand() % 3;
    P2_int_val = rand() % 3;
    
    if(P1_int_val == 0)
    {
        P1_string_val = "rock";
    }
    else if(P1_int_val == 1)
    {
        P1_string_val = "paper";
    }
    else
        P1_string_val = "scissors";
        
    if(P2_int_val == 0)
    {
        P2_string_val = "rock";
    }
    else if(P2_int_val == 1)
    {
        P2_string_val = "paper";
    }
    else
        P2_string_val = "scissors";
        
    cout << "Player 1 has " << P1_string_val << endl;
    cout << "Player 2 has " << P2_string_val << endl;
    
    if(Winner(P1_int_val,P2_int_val) == 0)
        cout << "Both Players Tied " << endl;
    else if(Winner(P1_int_val,P2_int_val) == 1)
        cout << "Player 1 wins! " << endl;
    else
        cout << "Player 2 wins! " << endl;

    return 0;
}
