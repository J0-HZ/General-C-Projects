/*
This program will check to see if an integer is a prime number or not

The function "IsPrime" uses a a number's remainder to see if it can only
be divided by 1 and itself

For example, if a user inputs 3:
  3 / 1 = 3 (remainder 0)
  3 / 2 = 1.5 (remainder 1)
  3 / 3 = 1 (remainder 0)
The divisor_count will be 2, hence 3 is prime.
*/

#include<iostream>
using namespace std;

bool IsPrime(int num)
{
    int divisor_count = 0;
    
    for(int i = 1; i <= num; i++)
    {
        if((num % i) == 0)
        {
            divisor_count++;
        }
    }
    if(divisor_count == 2)
    {
        return true;
    }
    else
        return false;
}

int main()
{
    unsigned int num;
    char again;
    
    do
    {
        cout << "Enter a positive integer: ";
        cin >> num;
        
        if(IsPrime(num))
        {
            cout << "That number is prime " << endl;
        }
        else
            cout << "That number is not prime " << endl;
        
        cout << "Do you want to quit?(y/Y) " << endl;
        cin >> again;
        
    }while(again == 'n' || again == 'N');
}
